# Supabase is expected to be connected through Vercel Marketplace.
# These names are synchronized by the integration for connected projects.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Legacy deployments can use SUPABASE_SERVICE_ROLE_KEY instead of
# SUPABASE_SECRET_KEY. Do not expose either secret with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=
