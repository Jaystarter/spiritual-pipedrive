# Supabase is expected to be connected through Vercel Marketplace.
# These names are synchronized by the integration for connected projects.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Legacy deployments can use SUPABASE_SERVICE_ROLE_KEY instead of
# SUPABASE_SECRET_KEY. Do not expose either secret with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=

# Web Push notifications for follow-up reminders.
# Generate with: npx web-push generate-vapid-keys --json
# The public key is safe to expose; the private key and cron secret are NOT.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@s-drive.app

# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
